<?xml version="1.0" encoding="utf-8"?>
<!--
    引擎选择界面布局
    APP 首次启动 / 每次启动时弹出，供用户选择播放引擎
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- 半透明黑色蒙层（TV 风格弹窗背景） -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- 居中卡片容器 -->
    <LinearLayout
        android:layout_width="480dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@color/bg_sidebar"
        android:padding="0dp">

        <!-- 标题栏 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="选择播放引擎"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@color/color_primary" />

        <!-- 副标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="请选择用于播放央视直播的浏览器引擎"
            android:textColor="@color/text_normal"
            android:textSize="14sp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="#444444" />

        <!-- ── 选项 1：GeckoView ── -->
        <LinearLayout
            android:id="@+id/btn_gecko"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:background="@drawable/selector_engine_item">

            <!-- 图标区域 -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@color/color_primary">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="FF"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- 文字区域 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GeckoView（Firefox 引擎）"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 推荐角标 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="推荐"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:background="@color/color_accent" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="不依赖系统 WebView · 内置 Firefox 引擎 · 最佳兼容性"
                    android:textColor="@color/text_normal"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 选中指示器 -->
            <View
                android:id="@+id/indicator_gecko"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/color_accent"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="#333333" />

        <!-- ── 选项 2：Crosswalk ── -->
        <LinearLayout
            android:id="@+id/btn_crosswalk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:background="@drawable/selector_engine_item">

            <!-- 图标区域 -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#1565C0">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="XW"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- 文字区域 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crosswalk（Chromium 引擎）"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="内置 Chromium 内核 · 适合 Android 7 及以下"
                    android:textColor="@color/text_normal"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 选中指示器 -->
            <View
                android:id="@+id/indicator_crosswalk"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/color_accent"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="#333333" />

        <!-- ── 选项 3：系统 WebView ── -->
        <LinearLayout
            android:id="@+id/btn_system"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:background="@drawable/selector_engine_item">

            <!-- 图标区域 -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#2E7D32">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="SYS"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- 文字区域 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="系统 WebView"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="轻量快速 · 无额外体积 · 依赖系统版本"
                    android:textColor="@color/text_normal"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 选中指示器 -->
            <View
                android:id="@+id/indicator_system"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/color_accent"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 底部按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="end">

            <!-- 记住选择 CheckBox 提示文字 -->
            <TextView
                android:id="@+id/tv_remember_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp"
                android:text="✓ 记住选择（下次直接进入）"
                android:textColor="@color/text_normal"
                android:textSize="12sp" />

            <!-- 重置记住选择 -->
            <TextView
                android:id="@+id/btn_reset_prefs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="重置"
                android:textColor="@color/text_normal"
                android:textSize="14sp"
                android:focusable="true"
                android:clickable="true"
                android:background="@color/channel_item_normal" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>

