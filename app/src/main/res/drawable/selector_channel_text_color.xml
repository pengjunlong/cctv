<?xml version="1.0" encoding="utf-8"?>
<!--
    频道名称文字颜色 Selector
    焦点/选中时显示白色，普通状态显示灰色
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点状态：白色 -->
    <item android:state_focused="true" android:color="@color/text_focused" />

    <!-- 选中状态：白色 -->
    <item android:state_selected="true" android:color="@color/text_focused" />

    <!-- activated 状态 -->
    <item android:state_activated="true" android:color="@color/text_focused" />

    <!-- 普通状态：灰色 -->
    <item android:color="@color/text_normal" />

</selector>

